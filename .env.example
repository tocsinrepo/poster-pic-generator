# Copy this file to `.env` and fill in YOUR OWN Higgsfield credentials.
# Get them from https://cloud.higgsfield.ai/ (account settings / API keys).
#
# IMPORTANT: `.env` is git-ignored on purpose. Never commit real credentials --
# this repo is public, and anyone who gets your key can spend your credits.

# Option 1: single combined key
HF_KEY=your-api-key:your-api-secret

# Option 2: separate key + secret (use this OR the single key above, not both)
# HF_API_KEY=your-api-key
# HF_API_SECRET=your-api-secret
